#include <mem.h>
#include <arm/armv7-a.dtsi>
#include <dt-bindings/interrupt-controller/arm-gic.h>

/ {
    soc {
        interrupt-parent = <&gicpl390>;

        cpus {
            #address-cells = <1>;
            #size-cells = <0>;

            cpu@0 {
                device_type = "cpu";
                compatible = "arm,cortex-a9";
                reg = <0>;
            };
        };

        gicpl390: interrupt-controller@f8f01000 {
            compatible = "arm,gic";
            reg = <0xf8f01000 0x1000>,
                  <0xf8f00100 0x100>;
            interrupt-controller;
            #interrupt-cells = <4>;
            label = "gic-pl390";
            status = "okay";
        };

        eth0: ethernet@e000b000 {
            compatible = "xlnx,emacps";
            reg = <0xe000b000 0x1000>;
            status = "okay";
            interrupts = <GIC_SPI 22 IRQ_TYPE_LEVEL IRQ_DEFAULT_PRIORITY>,
                         <GIC_SPI 23 IRQ_TYPE_LEVEL IRQ_DEFAULT_PRIORITY>;
            interrupt-names = "irq_0", "irq_1";
            label = "eth0";
            local-mac-address = [00 80 41 01 02 03];
        };

        eth1: ethernet@e000c000 {
            compatible = "xlnx,emacps";
            reg = <0xe000c000 0x1000>;
            status = "okay";
            interrupts = <GIC_SPI 45 IRQ_TYPE_LEVEL IRQ_DEFAULT_PRIORITY>,
                         <GIC_SPI 46 IRQ_TYPE_LEVEL IRQ_DEFAULT_PRIORITY>;
            interrupt-names = "irq_0", "irq_1";
            label = "eth1";
            local-mac-address = [00 80 41 02 03 04];
        };

        uart0: uart@e0000000 {
            compatible = "xlnx,xuartps";
            reg = <0xe0000000 0x4c>;
            status = "okay";
            interrupts = <GIC_SPI 27 IRQ_TYPE_LEVEL IRQ_DEFAULT_PRIORITY>;
            interrupt-names = "irq_0";
            label = "uart0";
            current-speed = <115200>;
            clock-frequency = <50000000>;
        };

        uart1: uart@e0001000 {
            compatible = "xlnx,xuartps";
            reg = <0xe0001000 0x4c>;
            status = "okay";
            interrupts = <GIC_SPI 50 IRQ_TYPE_LEVEL IRQ_DEFAULT_PRIORITY>;
            interrupt-names = "irq_0";
            label = "uart1";
            current-speed = <115200>;
            clock-frequency = <50000000>;
        };

        ttc0: timer@f8001000 {
            compatible = "cdns,ttc";
            status = "okay";
            interrupts = <GIC_SPI 10 IRQ_TYPE_LEVEL IRQ_DEFAULT_PRIORITY>,
                         <GIC_SPI 11 IRQ_TYPE_LEVEL IRQ_DEFAULT_PRIORITY>,
                         <GIC_SPI 12 IRQ_TYPE_LEVEL IRQ_DEFAULT_PRIORITY>;
            interrupt-names = "irq_0", "irq_1", "irq_2";
            reg = <0xf8001000 0x1000>;
            clock-frequency = <111111111>;
            label = "ttc0";
        };

        ttc1: timer@f8002000 {
            compatible = "cdns,ttc";
            status = "disabled";
            interrupts = <GIC_SPI 37 IRQ_TYPE_LEVEL IRQ_DEFAULT_PRIORITY>,
                         <GIC_SPI 38 IRQ_TYPE_LEVEL IRQ_DEFAULT_PRIORITY>,
                         <GIC_SPI 39 IRQ_TYPE_LEVEL IRQ_DEFAULT_PRIORITY>;
            interrupt-names = "irq_0", "irq_1", "irq_2";
            reg = <0xf8002000 0x1000>;
            clock-frequency = <111111111>;
            label = "ttc1";
        };
    };
};
