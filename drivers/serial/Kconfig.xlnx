config UART_XLNX_PS
	bool "Xilinx serial driver for MPSoC / Zynq7000"
	depends on SOC_XILINX_ZYNQMP || SOC_XILINX_ZYNQ7000
	select SERIAL_HAS_DRIVER
	help
	  This option enables the UART driver for Xilinx MPSoC platforms.
