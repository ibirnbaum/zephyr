# Xilinx AXI GPIO configuration options
# SPDX-License-Identifier: Apache-2.0
	
menuconfig GPIO_XLNX_AXI
	bool "Xilinx AXI GPIO driver"
	depends on SOC_XILINX_ZYNQ7000
	select HAS_DTS_GPIO
	help
	  Enable the Xilinx AXI GPIO driver. Please note that this
	  driver only supports the first channel of the AXI GPIO IP
	  core. The interrupt functionality of this driver is enabled
	  by specifying an interrupt line in the respective AXI GPIO's
	  device tree entry.
